  {
    "id": 1,
    "name": "番茄炒蛋",
    "category": "家常菜",
    "description": "番茄炒蛋是一道非常经典的家常菜，酸甜可口，营养丰富，老少皆宜。",
    "ingredients": [
      {"name": "番茄", "amount": "2个", "weight": "300克"},
      {"name": "鸡蛋", "amount": "3个", "weight": "150克"}
    ],
    "seasonings": [
      {"name": "食用油", "amount": "2汤勺", "weight": "20毫升"},
      {"name": "盐", "amount": "1/2茶勺", "weight": "3克"},
      {"name": "糖", "amount": "1茶勺", "weight": "5克"},
      {"name": "葱花", "amount": "适量", "weight": "10克"}
    ],
    "steps": [
      {"step": 1, "description": "番茄洗净，切成小块备用。"},
      {"step": 2, "description": "鸡蛋打入碗中，加入少许盐，用筷子打散均匀。"},
      {"step": 3, "description": "锅中倒入2汤勺食用油，烧至七成热。"},
      {"step": 4, "description": "倒入蛋液，用铲子快速翻炒至凝固，盛出备用。"},
      {"step": 5, "description": "锅中留少许底油，放入番茄块翻炒至出汁。"},
      {"step": 6, "description": "加入1茶勺糖和适量盐调味，继续翻炒均匀。"},
      {"step": 7, "description": "倒入炒好的鸡蛋，翻炒均匀，撒上葱花即可出锅。"}
    ],
    "cookingTime": "10分钟",
    "difficulty": "简单",
    "servings": "2人份",
    "tips": ["番茄要选择熟透的，这样炒出来更出汁。", "炒鸡蛋时油温要高，这样鸡蛋更蓬松。", "糖可以中和番茄的酸味，根据个人口味调整用量。"]
