    "steps": [
      {"step": 1, "description": "五花肉洗净，切成3厘米见方的块。"},
      {"step": 2, "description": "锅中加水，放入五花肉、姜片、葱段和1汤勺料酒，大火煮开后撇去浮沫，捞出五花肉备用。"},
      {"step": 3, "description": "锅中倒入1汤勺食用油，放入冰糖，小火炒至冰糖融化变成焦糖色。"},
      {"step": 4, "description": "放入五花肉块，翻炒均匀，使每块肉都裹上糖色。"},
      {"step": 5, "description": "加入姜片、葱段、八角、桂皮，翻炒出香味。"},
      {"step": 6, "description": "加入1汤勺料酒、2汤勺生抽、1汤勺老抽，翻炒均匀。"},
      {"step": 7, "description": "加入适量热水，水量要没过五花肉，大火煮开后转小火炖煮40分钟。"},
      {"step": 8, "description": "最后大火收汁，待汤汁浓稠即可出锅。"}
    ],
    "cookingTime": "60分钟",
    "difficulty": "中等",
    "servings": "3-4人份",
    "tips": ["五花肉要选择肥瘦相间的，这样口感更好。", "炒糖色时要用小火，避免炒糊变苦。", "炖煮时要用小火，这样肉更容易炖烂。", "最后收汁时要不停翻动，避免糊锅。"]
